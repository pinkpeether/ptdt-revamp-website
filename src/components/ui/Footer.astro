---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="footer-mark">P</div>
      <div>
        <strong>Peether PTDT</strong>
        <p>Decentralized settlement infrastructure for ride-hailing on BNB Chain.</p>
      </div>
    </div>
    <div class="footer-col">
      <h4>Protocol</h4>
      <a href="/protocol">Protocol</a>
      <a href="/tokenomics">Tokenomics</a>
      <a href="/security">Security</a>
    </div>
    <div class="footer-col">
      <h4>Build</h4>
      <a href="/developers">Developers</a>
      <a href="/downloads">Downloads</a>
      <a href="/ecosystem">Ecosystem</a>
    </div>
    <div class="footer-col">
      <h4>App</h4>
      <a href="/stake">Stake PTDT</a>
      <a href="/buy">Buy PTDT</a>
      <a href="/dashboard">Dashboard</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {year} Peether PTDT.</span>
    <span>Infrastructure, not an app.</span>
  </div>
</footer>

<style>
.site-footer { background:#0c0c14; color:#fff; padding:56px 0 24px; }
.footer-grid { display:grid; grid-template-columns:1.3fr 1fr 1fr 1fr; gap:28px; padding-bottom:28px; border-bottom:1px solid rgba(255,255,255,.08); }
.footer-brand { display:flex; gap:14px; align-items:flex-start; }
.footer-mark { width:46px; height:46px; border-radius:14px; display:grid; place-items:center; background:linear-gradient(135deg,var(--pink),#ff58b4); color:#fff; font-weight:900; }
.footer-brand strong { display:block; font-size:16px; margin-bottom:6px; }
.footer-brand p { color:rgba(255,255,255,.45); line-height:1.7; font-size:14px; max-width:320px; }
.footer-col { display:flex; flex-direction:column; gap:10px; }
.footer-col h4 { font-size:12px; text-transform:uppercase; letter-spacing:.08em; color:rgba(255,255,255,.35); font-family:var(--font-mono); margin-bottom:4px; }
.footer-col a { color:rgba(255,255,255,.75); font-size:14px; }
.footer-col a:hover { color:var(--pink); }
.footer-bottom { display:flex; justify-content:space-between; gap:12px; padding-top:18px; color:rgba(255,255,255,.35); font-size:12px; font-family:var(--font-mono); }
@media (max-width: 900px) { .footer-grid { grid-template-columns:1fr 1fr; } .footer-bottom { flex-direction:column; } }
@media (max-width: 560px) { .footer-grid { grid-template-columns:1fr; } }
</style>
