---
const nav = [
  { href:"/protocol", label:"Protocol" },
  { href:"/tokenomics", label:"Tokenomics" },
  { href:"/security", label:"Security" },
  { href:"/ecosystem", label:"Ecosystem" },
  { href:"/developers", label:"Developers" },
  { href:"/legacy", label:"Legacy" },
];
const path = Astro.url.pathname;
---
<header class="nav-shell">
  <div class="container nav-bar">
    <a href="/" class="brand" aria-label="PTDT Home">
      <div class="brand-mark">P</div>
      <div class="brand-copy">
        <strong>Peether PTDT</strong>
        <span>Settlement Protocol</span>
      </div>
    </a>
    <nav class="nav-links" aria-label="Main navigation">
      {nav.map((item) => (
        <a href={item.href} class={path === item.href ? "is-active" : undefined}>{item.label}</a>
      ))}
    </nav>
    <div class="nav-actions">
      <a href="/stake" class="btn btn-primary nav-btn">Stake</a>
    </div>
  </div>
</header>

<style>
.nav-shell { position:fixed; inset:18px 0 auto; z-index:1000; }
.nav-bar { display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:18px; min-height:72px; padding:10px 16px; border-radius:24px; background:rgba(255,255,255,.78); backdrop-filter:blur(18px); border:1px solid rgba(16,16,24,.08); box-shadow:0 16px 40px rgba(16,16,24,.08); }
.brand { display:flex; align-items:center; gap:12px; min-width:0; }
.brand-mark { width:44px; height:44px; border-radius:14px; display:grid; place-items:center; background:linear-gradient(135deg,var(--pink),#ff58b4); color:#fff; font-weight:900; box-shadow:0 12px 24px rgba(251,11,140,.2); }
.brand-copy { display:flex; flex-direction:column; }
.brand-copy strong { font-size:14px; line-height:1.1; color:var(--ink); }
.brand-copy span { font-size:11px; color:var(--muted); font-family:var(--font-mono); }
.nav-links { display:flex; justify-content:center; gap:6px; flex-wrap:wrap; }
.nav-links a { padding:10px 14px; border-radius:999px; font-size:13px; font-weight:700; color:var(--muted); transition:background .2s,color .2s; }
.nav-links a:hover, .nav-links a.is-active { background:var(--pink-soft); color:var(--pink); }
.nav-btn { min-height:42px; padding-inline:18px; }
@media (max-width: 920px) { .nav-bar { grid-template-columns:1fr; gap:12px; padding:14px; } .nav-links { justify-content:flex-start; } .nav-actions { width:100%; } .nav-btn { width:100%; } }
</style>
