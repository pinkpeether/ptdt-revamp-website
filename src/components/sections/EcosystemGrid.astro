---
import SectionTag from "@components/ui/SectionTag.astro";
const apps = [
  { href:"/dashboard",         icon:"📡", name:"Explorer",    sub:"On-chain data" },
  { href:"https://dapp.ptdt.taxi", icon:"🎛️", name:"Cockpit",    sub:"Protocol dApp" },
  { href:"/stake",             icon:"🔒", name:"Staking",     sub:"Earn yield" },
  { href:"/developers",        icon:"⚙️", name:"Developers",  sub:"API & SDK" },
  { href:"/downloads",         icon:"📥", name:"Downloads",   sub:"Tools & docs" },
  { href:"/tokenomics",        icon:"🪙", name:"Tokenomics",  sub:"Token model" },
  { href:"/security",          icon:"🛡️", name:"Security",    sub:"Audit report" },
  { href:"/legacy",            icon:"♥",  name:"Legacy",      sub:"Our origin" },
  { href:"/buy",               icon:"💱", name:"Buy PTDT",    sub:"Exchanges" },
  { href:"/ecosystem",         icon:"🌐", name:"Ecosystem",   sub:"All surfaces" },
];
---
<section class="section ecosystem-section" id="ecosystem">
  <div class="container">
    <div style="text-align:center; margin-bottom:var(--space-12)">
      <SectionTag color="green">Ecosystem</SectionTag>
      <h2 class="section-h2" style="margin-top:var(--space-4)">
        One Protocol.<br/><em>Many Surfaces.</em>
      </h2>
    </div>
    <div class="eco-grid">
      {apps.map(app => (
        <a href={app.href} class="eco-card" target={app.href.startsWith("http") ? "_blank" : undefined} rel={app.href.startsWith("http") ? "noopener noreferrer" : undefined}>
          <div class="eco-icon">{app.icon}</div>
          <div class="eco-name">{app.name}</div>
          <div class="eco-sub">{app.sub}</div>
        </a>
      ))}
    </div>
  </div>
</section>
