---
import SectionTag from "@components/ui/SectionTag.astro";
const apps = [
  { href:"/dashboard", icon:"📡", name:"Explorer", sub:"On-chain data" },
  { href:"https://dapp.ptdt.taxi", icon:"🎛️", name:"Cockpit", sub:"Protocol dApp" },
  { href:"/stake", icon:"🔒", name:"Staking", sub:"Earn yield" },
  { href:"/developers", icon:"⚙️", name:"Developers", sub:"API & SDK" },
  { href:"/downloads", icon:"📥", name:"Downloads", sub:"Tools & docs" },
  { href:"/tokenomics", icon:"🪙", name:"Tokenomics", sub:"Token model" },
  { href:"/security", icon:"🛡️", name:"Security", sub:"Audit report" },
  { href:"/legacy", icon:"♥", name:"Legacy", sub:"Our origin" },
  { href:"/buy", icon:"💱", name:"Buy PTDT", sub:"Exchanges" },
  { href:"/ecosystem", icon:"🌐", name:"Ecosystem", sub:"All surfaces" },
];
---
<section class="section ecosystem-section" id="ecosystem">
  <div class="container">
    <div class="eco-head">
      <SectionTag color="green">Ecosystem</SectionTag>
      <h2 class="section-h2 eco-title">One Protocol.<br /><em>Many Surfaces.</em></h2>
    </div>
    <div class="eco-grid">
      {apps.map((app) => (
        <a href={app.href} class="eco-card" target={app.href.startsWith("http") ? "_blank" : undefined} rel={app.href.startsWith("http") ? "noopener noreferrer" : undefined}>
          <div class="eco-icon">{app.icon}</div>
          <div class="eco-name">{app.name}</div>
          <div class="eco-sub">{app.sub}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.ecosystem-section { background:#fff; }
.eco-head { text-align:center; margin-bottom:42px; }
.eco-title { margin-top:16px; }
.eco-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; }
.eco-card { display:flex; flex-direction:column; align-items:center; gap:6px; padding:24px 16px; border-radius:20px; background:var(--mist); border:1px solid var(--line); text-align:center; transition:transform .2s, border-color .2s, background .2s; }
.eco-card:hover { transform:translateY(-3px); border-color:var(--pink-line); background:#fff; }
.eco-icon { font-size:24px; }
.eco-name { font-size:13px; font-weight:800; color:var(--ink); }
.eco-sub { font-size:11px; color:var(--muted); }
@media (max-width: 1000px) { .eco-grid { grid-template-columns:repeat(3,1fr); } }
@media (max-width: 640px) { .eco-grid { grid-template-columns:repeat(2,1fr); } }
</style>
