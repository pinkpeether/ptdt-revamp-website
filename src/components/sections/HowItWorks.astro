---
import SectionTag from "@components/ui/SectionTag.astro";
const steps = [
  { n: "01", title: "Demand", desc: "A rider requests a trip. The platform submits fare details to the PTDT Settlement API.", icon: "🚖", color: "pink" },
  { n: "02", title: "Settlement", desc: "PTDT routes the fare on-chain via BNB Chain. Protocol fee is deducted and split: 60% burned, 40% to stakers.", icon: "⛓️", color: "purple" },
  { n: "03", title: "Reward", desc: "Driver receives payment. Stakers earn real yield. PTDT supply decreases. Receipt is permanently on-chain.", icon: "✅", color: "green" },
];
---
<section class="section how-section" id="how-it-works">
  <div class="container">
    <div class="how-head">
      <SectionTag color="purple">How PTDT Works</SectionTag>
      <h2 class="section-h2 how-title">From Demand to <em>Settlement</em></h2>
      <p class="section-sub how-sub">Three steps. One protocol. Zero custodial risk.</p>
    </div>
    <div class="how-grid">
      {steps.map((s, i) => (
        <article class={`how-card ${s.color}`}>
          <div class="how-step">{s.n}</div>
          <div class="how-icon">{s.icon}</div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
          {i < 2 && <span class="how-arrow">→</span>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.how-section { background: var(--ink); color: #fff; }
.how-head { text-align:center; margin-bottom: 48px; }
.how-title { color:#fff; margin-top: 16px; }
.how-sub { color: rgba(255,255,255,.45); margin: 12px auto 0; text-align:center; }
.how-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.how-card { position:relative; border-radius:24px; padding:34px 28px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09); }
.how-card.pink { border-top:3px solid var(--pink); }
.how-card.purple { border-top:3px solid var(--purple); }
.how-card.green { border-top:3px solid var(--green-light); }
.how-step { font-size:11px; font-family:var(--font-mono); font-weight:800; color:rgba(255,255,255,.28); letter-spacing:.1em; margin-bottom:16px; }
.how-icon { font-size:32px; margin-bottom:16px; }
.how-card h3 { font-size:22px; font-weight:900; color:#fff; margin-bottom:10px; letter-spacing:-.03em; }
.how-card p { font-size:14px; color:rgba(255,255,255,.45); line-height:1.7; }
.how-arrow { position:absolute; top:50%; right:-17px; transform:translateY(-50%); color:rgba(255,255,255,.16); font-size:22px; }
@media (max-width: 900px) { .how-grid { grid-template-columns:1fr; } .how-arrow { display:none; } }
</style>
