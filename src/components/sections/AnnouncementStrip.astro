<div class="top-strip">
  <div class="strip-inner">
    <div class="strip-badge">
      <span class="pulse-dot"></span>
      LIVE
    </div>
    <span class="strip-text">
      PTDT Settlement Protocol is live on BNB Chain —
      <a href="/tokenomics">View Tokenomics</a> &nbsp;·&nbsp;
      <a href="/stake">Stake Now</a> &nbsp;·&nbsp;
      <a href="/security">9.2/10 Audit</a>
    </span>
  </div>
</div>

<style>
  .top-strip {
    background: #0a0a0f;
    min-height: 44px; display: grid; place-items: center;
    padding: 0 24px;
  }
  .strip-inner {
    display: flex; align-items: center; gap: 12px;
    font-size: 13px; color: rgba(255,255,255,0.6);
    font-weight: 600;
  }
  .strip-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 10px; border-radius: var(--radius-full);
    background: rgba(42,233,123,0.12); border: 1px solid rgba(42,233,123,0.22);
    font-size: 10px; font-weight: 900; color: var(--green-light);
    font-family: var(--font-mono); letter-spacing: 0.08em;
    flex-shrink: 0;
  }
  .strip-text a { color: var(--pink); font-weight: 700; }
  .strip-text a:hover { text-decoration: underline; }
</style>
