---
import SectionTag from "@components/ui/SectionTag.astro";
import SettlementApiDrawer from "@components/islands/SettlementApiDrawer";
---

<section class="section why-section" id="why-peether">
  <div class="container">
    <div class="why-grid">
      <!-- LEFT: Image -->
      <div class="why-image-wrap">
        <img src="/image-to-use.png" alt="Peether PTDT — decentralized ride-hailing settlement" loading="lazy" />
        <div class="why-image-badge">
          <div class="badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <div class="badge-val">9.2 / 10</div>
            <div class="badge-lbl">Smart Contract Audit Score</div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Copy -->
      <div class="why-copy">
        <SectionTag color="pink">Why Peether</SectionTag>
        <h2 class="section-h2">
          A Mobility Network<br/><em>Built for Web3</em>
        </h2>
        <p class="section-sub">
          PTDT is infrastructure — not an app. Any ride-hailing platform can plug into
          the protocol and settle fares on-chain with full transparency and zero
          custodial risk.
        </p>

        <ul class="check-list">
          <li>
            <span class="check-icon">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2">
                <polyline points="2 6 5 9 10 3"/>
              </svg>
            </span>
            Ride fares settled on BNB Chain — transparent, auditable, permissionless.
          </li>
          <li>
            <span class="check-icon">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2">
                <polyline points="2 6 5 9 10 3"/>
              </svg>
            </span>
            60% of every protocol fee is permanently burned — deflationary by design.
          </li>
          <li>
            <span class="check-icon">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2">
                <polyline points="2 6 5 9 10 3"/>
              </svg>
            </span>
            40% flows to stakers — real yield from real settlement volume.
          </li>
          <li>
            <span class="check-icon">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2">
                <polyline points="2 6 5 9 10 3"/>
              </svg>
            </span>
            Women-safety origin story — Pink Taxi Group, est. 2019, UK registered.
          </li>
        </ul>

        <!-- Contract box -->
        <div class="contract-box">
          <div style="flex:1">
            <div class="contract-label">PTDT Token · BNB Smart Chain</div>
            <div class="contract-addr" id="why-contract-addr">0x0000000000000000000000000000000000000000</div>
          </div>
          <span class="contract-badge">BEP-20</span>
          <button
            onclick="navigator.clipboard.writeText(document.getElementById('why-contract-addr').textContent ?? '')"
            style="color:rgba(255,255,255,0.4);font-size:16px;padding:4px;flex-shrink:0;"
            aria-label="Copy contract address"
          >⎘</button>
        </div>

        <!-- CTAs -->
        <div class="why-cta-row">
          <a href="/buy" class="btn btn-primary">Buy PTDT</a>

          <!--
            Settlement API button:
            Fires a custom event → SettlementApiDrawer island catches it and
            opens the in-page drawer. NO new page / window.open().
          -->
          <button
            class="btn btn-ghost"
            onclick="window.dispatchEvent(new CustomEvent('ptdt:open-settlement-api'))"
            aria-label="Open Settlement API reference"
          >
            Settlement API
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Settlement API Drawer island — rendered once globally -->
<SettlementApiDrawer client:load />

<style>
  .why-section { background: var(--paper); }
  .why-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 72px; align-items: center;
  }
  .why-copy { display: flex; flex-direction: column; gap: 0; }
  .why-cta-row { display: flex; gap: 12px; margin-top: var(--space-8); flex-wrap: wrap; }
  @media (max-width: 860px) {
    .why-grid { grid-template-columns: 1fr; gap: var(--space-10); }
    .why-image-wrap { order: -1; }
  }
</style>
