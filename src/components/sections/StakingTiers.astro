---
import SectionTag from "@components/ui/SectionTag.astro";
const tiers = [
  { id:"bronze", label:"Bronze", apy:12, minStake:10, lockDays:30, color:"#cd7f32", bullets:["Entry level staking","30-day lock period","Earn from settlement fees"] },
  { id:"silver", label:"Silver", apy:15, minStake:100, lockDays:60, color:"#94a3b8", bullets:["Mid-tier staking","60-day lock period","Priority queue access"] },
  { id:"gold", label:"Gold", apy:18, minStake:500, lockDays:90, color:"#fb0b8c", bullets:["Premium staking","90-day lock period","Highest protocol yield"] },
];
---
<section class="section staking-section" id="staking">
  <div class="container">
    <div class="stake-head">
      <SectionTag color="green">Staking Tiers</SectionTag>
      <h2 class="section-h2 stake-title">Stake PTDT.<br /><em>Earn Real Yield.</em></h2>
      <p class="section-sub stake-sub">40% of every protocol settlement fee flows to stakers. No inflation. No tricks.</p>
    </div>
    <div class="tiers-grid">
      {tiers.map((t) => (
        <article class={`tier-card ${t.id}`}>
          <span class="tier-badge">{t.label}</span>
          <div class="tier-apy" style={`color:${t.color}`}>{t.apy}<span>%</span></div>
          <div class="tier-min">Min. {t.minStake} PTDT</div>
          <ul class="tier-list">
            {t.bullets.map((b) => <li><span style={`color:${t.color}`}>•</span>{b}</li>)}
          </ul>
          <div class="tier-lock">🔒 {t.lockDays}-day lock</div>
          <a href="/stake" class="btn btn-primary tier-btn">Stake {t.label}</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.staking-section { background: var(--paper); }
.stake-head { text-align:center; margin-bottom:48px; }
.stake-title { margin-top:16px; }
.stake-sub { margin:12px auto 0; text-align:center; }
.tiers-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
.tier-card { border-radius:28px; border:1px solid var(--line); background:#fff; padding:28px; box-shadow:var(--shadow-sm); display:flex; flex-direction:column; }
.tier-card.bronze { border-top:3px solid #cd7f32; }
.tier-card.silver { border-top:3px solid #94a3b8; }
.tier-card.gold { border-top:3px solid var(--pink); }
.tier-badge { font-size:10px; font-weight:900; text-transform:uppercase; letter-spacing:.08em; font-family:var(--font-mono); color:var(--muted-2); }
.tier-apy { font-size:3.2rem; font-weight:900; line-height:1; letter-spacing:-.06em; margin:14px 0 8px; }
.tier-apy span { font-size:1.2rem; }
.tier-min { font-size:12px; color:var(--muted); font-family:var(--font-mono); margin-bottom:16px; }
.tier-list { list-style:none; display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
.tier-list li { display:flex; gap:8px; font-size:13px; color:var(--muted); align-items:flex-start; }
.tier-lock { font-size:11px; color:var(--muted-2); font-family:var(--font-mono); margin-top:auto; }
.tier-btn { width:100%; margin-top:20px; }
@media (max-width: 900px) { .tiers-grid { grid-template-columns:1fr; } }
</style>
