<section class="footer-cta-section">
  <div class="container">
    <div class="footer-cta-inner">
      <h2 class="footer-cta-h2">Ready to Explore the Protocol?</h2>
      <p class="footer-cta-sub">Integrate PTDT into your platform. Stake tokens. Explore on-chain data.</p>
      <div class="footer-cta-btns">
        <a href="/developers" class="btn btn-primary">Start Building</a>
        <a href="/ecosystem" class="btn btn-ghost footer-ghost">Explore Ecosystem</a>
      </div>
    </div>
  </div>
</section>

<style>
.footer-cta-section { background: linear-gradient(135deg, var(--ink) 0%, #1b0f2a 100%); padding: clamp(var(--space-16), 8vw, var(--space-24)) 0; }
.footer-cta-inner { text-align:center; max-width:580px; margin:0 auto; }
.footer-cta-h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight:900; color:#fff; letter-spacing:-.05em; margin-bottom:16px; }
.footer-cta-sub { font-size:16px; color:rgba(255,255,255,.45); margin-bottom:32px; line-height:1.7; }
.footer-cta-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
.footer-ghost { background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.14); color:#fff; }
.footer-ghost:hover { border-color:var(--pink-line); color:var(--pink); }
</style>
