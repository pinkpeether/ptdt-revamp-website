---
import BaseLayout from "@layouts/BaseLayout.astro";
import AnnouncementStrip from "@components/sections/AnnouncementStrip.astro";
import Hero from "@components/sections/Hero.astro";
import MarqueeStrip from "@components/sections/MarqueeStrip.astro";
import StatsBar from "@components/sections/StatsBar.astro";
import WhyPeether from "@components/sections/WhyPeether.astro";
import HowItWorks from "@components/sections/HowItWorks.astro";
import FeeModel from "@components/sections/FeeModel.astro";
import StakingTiers from "@components/sections/StakingTiers.astro";
import EcosystemGrid from "@components/sections/EcosystemGrid.astro";
import Roadmap from "@components/sections/Roadmap.astro";
import LegacyOrigin from "@components/sections/LegacyOrigin.astro";
import FooterCTA from "@components/sections/FooterCTA.astro";
---

<BaseLayout
  title="Decentralized Settlement Infrastructure for Ride-Hailing"
  description="PTDT is the decentralized settlement protocol for global ride-hailing on BNB Chain. 60% burned. 40% to stakers. Real yield from real settlement volume."
>
  <AnnouncementStrip />
  <Hero />
  <MarqueeStrip />
  <StatsBar />
  <WhyPeether />
  <HowItWorks />
  <FeeModel />
  <StakingTiers />
  <EcosystemGrid />
  <Roadmap />
  <LegacyOrigin />
  <FooterCTA />
</BaseLayout>
