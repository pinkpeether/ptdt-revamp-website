{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@layouts/*":    ["src/layouts/*"],
      "@components/*": ["src/components/*"],
      "@styles/*":     ["src/styles/*"],
      "@lib/*":        ["src/lib/*"],
      "@types/*":      ["src/types/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
